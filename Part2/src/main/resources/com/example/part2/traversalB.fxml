<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="traversalB" alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.part2.TraversalBController">
   <children>
      <Label text="Contact Information">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <TableView fx:id="dataTable" prefHeight="200.0" prefWidth="200.0">
         <columns>
            <TableColumn fx:id="nameColumn" prefWidth="150.0" text="Name" />
            <TableColumn fx:id="surnameColumn" prefWidth="150.0" text="Surname" />
            <TableColumn fx:id="phoneColumn" prefWidth="150.0" text="Phone" />
            <TableColumn fx:id="emailColumn" prefWidth="150.0" text="Email" />
         </columns>
      </TableView>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
         <children>
            <Button fx:id="backBtn" mnemonicParsing="false" onAction="#goHome" prefHeight="25.0" prefWidth="95.0" text="Back" />
         </children>
      </HBox>
      <Label fx:id="notFoundMsg" prefHeight="17.0" prefWidth="174.0" text="       No contact was found!" textFill="#e20808" visible="false" />
   </children>
</VBox>
