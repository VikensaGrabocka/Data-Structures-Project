<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="insertBox" alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.part2.InsertController">
   <children>
      <Label alignment="CENTER" contentDisplay="CENTER" text="Insert New Contact" textAlignment="CENTER">
         <font>
            <Font size="23.0" />
         </font>
      </Label>
      <VBox alignment="CENTER" prefHeight="190.0" prefWidth="600.0">
         <children>
            <VBox prefHeight="295.0" prefWidth="600.0">
               <children>
                  <TextField alignment="CENTER" text="Contact Information">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                     <opaqueInsets>
                        <Insets left="40.0" right="40.0" />
                     </opaqueInsets>
                     <VBox.margin>
                        <Insets left="40.0" right="40.0" top="20.0" />
                     </VBox.margin>
                  </TextField>
                  <TextField fx:id="name" promptText="Name">
                     <VBox.margin>
                        <Insets left="40.0" right="40.0" />
                     </VBox.margin>
                  </TextField>
                  <TextField fx:id="surname" promptText="Surname">
                     <VBox.margin>
                        <Insets left="40.0" right="40.0" />
                     </VBox.margin>
                  </TextField>
                  <TextField fx:id="phone" promptText="Phone">
                     <VBox.margin>
                        <Insets left="40.0" right="40.0" />
                     </VBox.margin>
                  </TextField>
                  <TextField fx:id="email" promptText="Email">
                     <VBox.margin>
                        <Insets left="40.0" right="40.0" />
                     </VBox.margin>
                  </TextField>
                  <Label text="Position:">
                     <VBox.margin>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </VBox.margin>
                  </Label>
                  <HBox prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <RadioButton fx:id="beginningBtn" lineSpacing="15.0" mnemonicParsing="false" onAction="#insertAtBeginning" text="At the beginning">
                           <HBox.margin>
                              <Insets left="20.0" right="20.0" />
                           </HBox.margin>
                           <toggleGroup>
                              <ToggleGroup fx:id="Option" />
                           </toggleGroup>
                        </RadioButton>
                        <RadioButton fx:id="endBtn" contentDisplay="CENTER" lineSpacing="20.0" mnemonicParsing="false" onAction="#insertAtEnd" text="At the end" toggleGroup="$Option" />
                        <RadioButton fx:id="positionBtn" contentDisplay="CENTER" lineSpacing="20.0" mnemonicParsing="false" onAction="#position" text="At a specific position" toggleGroup="$Option">
                           <HBox.margin>
                              <Insets left="20.0" right="20.0" />
                           </HBox.margin>
                        </RadioButton>
                        <TextField fx:id="posField" prefHeight="25.0" prefWidth="57.0" promptText="Position" visible="false" />
                     </children>
                  </HBox>
               </children>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </VBox>
         </children>
      </VBox>
      <HBox alignment="CENTER" prefHeight="66.0" prefWidth="600.0" spacing="10.0">
         <children>
            <Button fx:id="backBtn" mnemonicParsing="false" onAction="#goHome" text="Back" />
            <Button fx:id="OkBtn" mnemonicParsing="false" onAction="#insert" text="OK" />
         </children>
      </HBox>
      <Label fx:id="warningMsg" text="Please fill all the fields!" textFill="#be0202" visible="false" />
      <Label fx:id="successMsg" text="Contact inserted successfully!" textFill="#05723a" visible="false" />
   </children>
</VBox>
